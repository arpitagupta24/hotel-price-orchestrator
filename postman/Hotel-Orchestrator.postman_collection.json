{
  "info": {
    "name": "Hotel Offer Orchestrator",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json",
    "description": "Assessment API: hotels orchestration, suppliers, health."
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3001"
    }
  ],
  "item": [
    {
      "name": "GET /api/hotels — Delhi (overlaps)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/hotels?city=delhi"
      }
    },
    {
      "name": "GET /api/hotels — price range (Redis filter)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/hotels?city=delhi&minPrice=5000&maxPrice=6000"
      }
    },
    {
      "name": "GET /api/hotels — city with no results",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/api/hotels?city=berlin"
      }
    },
    {
      "name": "GET /supplierA/hotels",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/supplierA/hotels?city=delhi"
      }
    },
    {
      "name": "GET /supplierB/hotels",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/supplierB/hotels?city=delhi"
      }
    },
    {
      "name": "Optional — Supplier A simulated down",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/supplierA/hotels?city=delhi&simulateDown=1"
      }
    },
    {
      "name": "GET /health",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{baseUrl}}/health"
      }
    }
  ]
}
