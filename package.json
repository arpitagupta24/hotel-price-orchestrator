{
  "name": "hotel-offer-orchestrator",
  "version": "1.0.0",
  "private": true,
  "description": "Hotel Offer Orchestrator — Express, Temporal, Redis",
  "scripts": {
    "build": "tsc",
    "start:api": "node dist/server.js",
    "start:worker": "node dist/temporal/worker.js",
    "dev:api": "tsx watch src/server.ts",
    "dev:worker": "tsx watch src/temporal/worker.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
