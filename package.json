    "@temporalio/workflow": "^1.11.3",
    "express": "^4.21.2",
    "ioredis": "^5.6.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
